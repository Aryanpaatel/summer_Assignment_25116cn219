#include <stdio.h>
void main()
    {
        int n,m,lcm;
        printf("\nEnter the values of n and m: ");
        scanf("%d %d",&n,&m);
        if(m>n)
        lcm=m;
        else
        lcm=n;
        while (1)
        {
            if(lcm%n==0 && lcm%m==0)
            {
                printf("\nThe LCM of %d and %d is %d",n,m,lcm);
                break;
            }
            lcm++;
            /* code */
        }
              
    }
