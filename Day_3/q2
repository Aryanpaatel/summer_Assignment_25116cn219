#include <stdio.h>

int main()
{
    int num,p=2,i;
    printf("Enter a number: ");
    scanf("%d", &num);
    while(num)
    {
        for(i=2;i<=p;i++)
        {
            if(p%i==0)
                break;
        
        }
    }
    if(i==p)
    {
        printf("%d ",p);
    }

    return 0;
}
