#include <stdio.h>
int armstrong(int n) {
int r, sum = 0, temp;
temp = n;
while(n > 0) {
r = n % 10;
sum = sum + (r * r * r); 
n = n / 10;
}
if(sum == temp)
return 1;
else
return 0;
}
int main() {
int num;
printf("Enter number: ");
scanf("%d", &num);
if(armstrong(num))
printf("Armstrong number\n");
else
printf("Not Armstrong number\n");
return 0;
}

